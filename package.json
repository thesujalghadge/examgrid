{
  "name": "examgrid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rimraf .next && next dev",
    "build": "rimraf .next/dev/types && next build",
    "start": "next start",
    "lint": "eslint src proxy.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.mjs",
    "test:integration": "vitest run --config vitest.integration.config.mjs",
    "db:bootstrap": "node scripts/supabase/bootstrap-db.mjs",
    "db:push": "npx supabase db push",
    "db:verify": "node scripts/supabase/verify-remote.mjs",
    "db:setup": "npm run db:bootstrap && npm run db:verify",
    "deploy:check": "node scripts/validate-deployment.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "recover:solutions": "npx tsx scripts/recover_solutions.ts",
    "rescore:exam": "npx tsx scripts/rescore_exam.ts",
    "queue:status": "npx tsx scripts/system_health.ts",
    "unlock:worker": "npx tsx scripts/unlock_worker.ts",
    "reset:demo": "npx tsx scripts/reset_demo.ts",
    "verify:demo": "npx tsx --env-file=.env.local scripts/verify_demo.ts",
    "demo:prepare": "npm run reset:demo && npm run verify:demo",
    "verify:security": "npx tsx --env-file=.env.local scripts/verify_test_id_integrity.ts && npx tsx --env-file=.env.local scripts/verify_rpc_integrity.ts && npx tsx --env-file=.env.local scripts/verify_rank_engine.ts",
    "verify:analytics": "npx tsx --env-file=.env.local scripts/verify_analytics_pipeline.ts",
    "load-test": "npx tsx --env-file=.env.local scripts/load_test_suite.ts",
    "verify:predeploy": "npm run verify:security && npm run verify:analytics && npm run test",
    "verify:production": "npx tsx --env-file=.env.local scripts/verify_production_health.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.105.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/katex": "^0.16.8",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-katex": "^3.0.4",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pg": "^8.22.0",
    "playwright": "^1.60.0",
    "rimraf": "^6.1.3",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
