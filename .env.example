# Repository: local (browser storage) | supabase (questions + exams in Postgres)
NEXT_PUBLIC_REPOSITORY_MODE=local

# Demo institute label used in docs/UI examples
NEXT_PUBLIC_DEMO_INSTITUTE_NAME=Apex JEE Academy

# Default institute UUID — must exist in Supabase (see supabase/schema/seed.sql)
NEXT_PUBLIC_DEFAULT_INSTITUTE_ID=00000000-0000-0000-0000-000000000001

# Supabase (public anon key is safe for client-side use with RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# CLI migration credentials (gitignored — add to .env.local only)
# Use ONE of:
# SUPABASE_ACCESS_TOKEN=   # https://supabase.com/dashboard/account/tokens
# SUPABASE_DB_PASSWORD=    # Dashboard → Project Settings → Database
